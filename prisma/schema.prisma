generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkflowStage {
  IDEA_POOL
  SELECTED
  RESEARCHING
  BRIEF_READY
  DRAFTING
  REVIEW
  APPROVED
  PUBLISHED
}

enum ResearchRegion {
  TH
  GLOBAL
}

enum WorkflowEventType {
  RESEARCH
  BRIEF
  DRAFT
  IMAGES
  PUBLISH
  FACEBOOK
}

enum WorkflowEventStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum UserRole {
  ADMIN
  CLIENT
}

enum AccountStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  passwordHash  String?
  role          UserRole      @default(CLIENT)
  status        AccountStatus @default(ACTIVE)
  contractStart DateTime?
  contractEnd   DateTime?
  clientId      String?
  client        Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sessions      AuthSession[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Client {
  id                 String       @id @default(cuid())
  name               String       @unique
  articlePrompt      String       @default("")
  expertisePrompt    String       @default("")
  brandVoicePrompt   String       @default("")
  researchProvider   String       @default("")
  wordpressUrl       String       @default("")
  wordpressUsername  String       @default("")
  wordpressAppPassword String     @default("")
  wordpressPublishStatus String   @default("draft")
  projects           Project[]
  keywordJobs        KeywordJob[]
  users              User[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model SystemConfig {
  id                  String   @id @default("global")
  articlePrompt       String   @default("")
  researchProvider    String   @default("tavily")
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id        String       @id @default(cuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  jobs      KeywordJob[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model KeywordJob {
  id             String          @id @default(cuid())
  clientId       String?
  client         Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  seedKeyword    String
  stage          WorkflowStage   @default(IDEA_POOL)
  selectedIdeaId String?
  ideas          TopicIdea[]
  researchPack   ResearchPack?
  contentBrief   ContentBrief?
  articleDraft   ArticleDraft?
  articleImages  ArticleImage[]
  facebookPost   FacebookPostDraft?
  workflowEvents WorkflowEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model TopicIdea {
  id              String       @id @default(cuid())
  jobId           String
  job             KeywordJob   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title           String
  angle           String
  searchIntent    String
  difficulty      String
  confidence      Int
  whyItMatters    String
  thaiSignal      String
  globalSignal    String
  relatedKeywords String[]
  createdAt       DateTime     @default(now())
}

model ResearchPack {
  id         String           @id @default(cuid())
  jobId       String          @unique
  job         KeywordJob      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  objective   String
  audience    String
  gaps        String[]
  sources     ResearchSource[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ResearchSource {
  id         String         @id @default(cuid())
  packId      String
  pack        ResearchPack  @relation(fields: [packId], references: [id], onDelete: Cascade)
  region      ResearchRegion
  title       String
  source      String
  insight     String
}

model ContentBrief {
  id              String      @id @default(cuid())
  jobId            String      @unique
  job              KeywordJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title            String
  slug             String
  metaTitle        String
  metaDescription  String
  audience         String
  angle            String
  publishStatus    String      @default("draft")
  categoryIds      String[]
  tagIds           String[]
  featuredImageUrl String      @default("")
  outline          String[]
  faqs             String[]
  internalLinks    String[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model ArticleDraft {
  id          String         @id @default(cuid())
  jobId        String         @unique
  job          KeywordJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  intro        String
  conclusion   String
  sections     DraftSection[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model DraftSection {
  id        String       @id @default(cuid())
  draftId    String
  draft      ArticleDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  heading    String
  body       String
  sortOrder  Int
}

model ArticleImage {
  id             String      @id @default(cuid())
  jobId          String
  job            KeywordJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  kind           String
  src            String
  alt            String
  caption        String
  placement      String
  prompt         String
  sectionHeading String?
  sortOrder      Int
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model FacebookPostDraft {
  id              String      @id @default(cuid())
  jobId           String      @unique
  job             KeywordJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  caption         String      @default("")
  hashtags        String[]
  selectedImageId String?
  status          String      @default("draft")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model WorkflowEvent {
  id            String              @id @default(cuid())
  jobId         String
  job           KeywordJob          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type          WorkflowEventType
  status        WorkflowEventStatus @default(QUEUED)
  source        String
  workflowRunId String?
  message       String?
  payload       Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}
